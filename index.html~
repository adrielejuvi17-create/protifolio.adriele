<script>
$(document).ready(function(){

    AOS.init();

    // Scroll suave
    $("nav a").click(function(e){
        e.preventDefault();
        let target = $(this).attr("href");
        $('html, body').animate({
            scrollTop: $(target).offset().top
        }, 800);
    });

  
});
</script>

