<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portfólio Profissional</title>

<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- AOS Animation -->
<link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>

<!-- css -->
<style>
:root {
    --roxo: #7b2cff;
    --preto: #0d0d0d;
    --cinza: #1a1a1a;
}



* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

a:link{ /* não visitado*/
color: white;
text-decoration: none;
}

a:visited{ /*visitado*/
text-decoration: none;
color: white;
}

a:hover{/* com o cursor pairado (em cima)*/
text-decoration: none;
color: white;
}

a:active{/* precionado*/
text-decoration: none;
color:  white;
}

body {
    font-family: 'Poppins', Times New Roman , sans-serif;
    background: var(--preto);
    color: #fff;
}

header {
    background: linear-gradient(100deg, #4b0082, #7b2cff);
    padding: 50px;
    text-align: center;
}

header h1 {
font-family: Times New Roman , Nimbus Roman , Liberation Serif, Plantin , Garamond, Heuristica ;
font-size: 50px;
    font-size: 2rem;
}

nav {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 10px;
    flex-wrap: wrap;
}

nav a {
font-family: Liberation Serif ;
font-size: 20px;
    color: #fff;
    text-decoration: none;
    font-weight: 400;
}

section {
    padding: 60px 20px;
    text-align: center;
    font-family: Liberation Serif, Times New Roman; 
    font-size: 20px
}

.container {
    max-width: 1100px;
    margin: auto;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.card {
    background: var(--cinza);
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 0 20px rgba(123, 44, 255, 0.2);
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-10px) scale(1.03);
}

button {
    background: var(--roxo);
    border: none;
    padding: 10px 20px;
    color: white;
    border-radius: 20px;
    cursor: pointer;
}

/* WhatsApp botão */
.whatsapp {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #25D366;
    color: white;
    padding: 15px 20px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: bold;
    box-shadow: 0 0 15px rgba(0,0,0,0.4);
}

footer {
    text-align: center;
    padding: 20px;
    background: #111;
}

p{
font-family: Linux Biolinum G ,sans-serif humanista, Linux Libertine ;
font-size: 20px ;
text-align: center;

}

/* RESPONSIVO */
@media (max-width: 768px) {
    header h1 {
        font-size: 1.5rem;
    }

    section {
        padding: 40px 15px;
    }
}

@media (max-width: 480px) {
    nav {
        flex-direction: column;
    }
}

</style>
</head>

